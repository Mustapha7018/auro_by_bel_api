# Copy to .env and adjust for your environment.

# SQLite by default; swap for Postgres in production, e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/aura
DATABASE_URL=sqlite:///./aura.db

# CHANGE THIS in production (used to sign JWTs)
JWT_SECRET=dev-secret-change-me-in-production

# Comma-separated allowed front-end origins
# (storefront prod domain is aurabybel.shop; add the dashboard's domain when it's deployed)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://aurabybel.shop,https://www.aurabybel.shop
